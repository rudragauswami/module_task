<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_list_inherit_priority_colors" model="ir.ui.view">
        <field name="name">mrp.production.list.inherit.priority.colors</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-warning">priority == '2'</attribute>
                <attribute name="decoration-danger">priority == '3'</attribute>
            </xpath>
        </field>
    </record>
</odoo>
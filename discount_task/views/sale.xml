<odoo>
    <record id="view_order_form_auto_discount_percent" model="ir.ui.view">
        <field name="name">sale.order.form.auto.discount.percent</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list//field[@name='discount']" position="attributes">

                <attribute name="groups"></attribute>

                <attribute name="readonly">1</attribute>

                <attribute name="force_save">1</attribute>

            </xpath>

        </field>
    </record>

    <record id="view_volume_discount_rule_tree" model="ir.ui.view">
        <field name="name">volume.discount.rule.tree</field>
        <field name="model">volume.discount.rule</field>
        <field name="arch" type="xml">
            <list string="Volume Discount Rules">
                <field name="name"/>
                <field name="min_qty"/>
                <field name="discount_pct"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_volume_discount_rule_form" model="ir.ui.view">
        <field name="name">volume.discount.rule.form</field>
        <field name="model">volume.discount.rule</field>
        <field name="arch" type="xml">
            <form string="Volume Discount Rules">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_ids" widget="many2many_tags"
                                   placeholder="Leave blank for all products"/>
                            <field name="min_qty"/>
                        </group>
                        <group>
                            <field name="discount_pct"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_volume_discount_rules" model="ir.actions.act_window">
        <field name="name">Volume Discount Rules</field>
        <field name="res_model">volume.discount.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_volume_discount_rules"
              name="Volume Discount Rules"
              parent="sale.menu_sale_config"
              action="action_volume_discount_rules"
              sequence="100"/>
</odoo>
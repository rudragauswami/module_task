<odoo>
    <record id="view_partner_form_inherit_credit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.credit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="total_invoices"/>
                <field name="total_payments_done"/>
                <field name="total_payments_remaining"/>
                <field name="total_left_credit"/>
            </xpath>
        </field>
    </record>
</odoo>
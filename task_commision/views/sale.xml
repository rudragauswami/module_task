<odoo>
    <record id="view_order_form_inherit_commission_fix" model="ir.ui.view">
        <field name="name">sale.order.form.commission.fix</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price_subtotal']" position="before">
            <field name="commission_amount"
                   string="Commission"
                   optional="show"
                   readonly="1"
                   force_save="1"/>
            </xpath>
        </field>
    </record>
</odoo>
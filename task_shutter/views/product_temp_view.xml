<odoo>
    <record id="product_template_form_view_shutter" model="ir.ui.view">
        <field name="name">product.template.common.form.shutter</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <field name="is_shutter_product"/>
                <field name="shutter_type_id" invisible="not is_shutter_product"/>
            </field>
        </field>
    </record>
</odoo>
<odoo>
    <record id="view_order_form_inherit_shutter_config" model="ir.ui.view">
        <field name="name">sale.order.form.shutter.config</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='product_template_id']" position="after">

                <field name="suggested_shutter_type_id" readonly="1" column_invisible="1" invisible="product_id"/>
                <field name="product_id" domain="[('id', 'in', allowed_shutter_product_ids)]"/>
                <field name="range_config_id" column_invisible="1" invisible="1"/>
                <field name="allowed_lock_ids" column_invisible="1" invisible="1"/>
                <field name="allowed_stopper_ids" column_invisible="1" invisible="1"/>
                <field name="allowed_blade_ids" column_invisible="1" invisible="1"/>

                <field name="shutter_height"
                       optional="show"
                       readonly="0"
                />

                <field name="shutter_width"
                       optional="show"
                       readonly="0"
                />

                <field name="lock_product_id"
                       readonly="0"
                       optional="show"
                       domain="[('id', 'in', allowed_lock_ids)]"
                       column_invisible="not parent.has_shutter_products"
                       invisible="not range_config_id"/>

                <field name="stopper_product_id"
                       readonly="0"
                       optional="show"
                       domain="[('id', 'in', allowed_stopper_ids)]"
                       column_invisible="not parent.has_shutter_products"
                       invisible="not range_config_id"/>

                <field name="blade_product_id"
                       readonly="0"
                       optional="show"
                       domain="[('id', 'in', allowed_blade_ids)]"
                       column_invisible="not parent.has_shutter_products"
                       invisible="not range_config_id"/>

                <field name="blade_qty"
                       readonly="1"
                       optional="show"
                       column_invisible="not parent.has_shutter_products"
                       invisible="not range_config_id"/>

                <field name="component_price_total"
                       readonly="1"
                       optional="show"
                       column_invisible="not parent.has_shutter_products"
                       invisible="not range_config_id"/>

            </xpath>
        </field>
    </record>
</odoo>
<odoo>
    <!--  List View -->
    <record id="view_shutter_range_config_tree" model="ir.ui.view">
        <field name="name">shutter.range.config.tree</field>
        <field name="model">shutter.range.config</field>
        <field name="arch" type="xml">
            <list string="Shutter Range Configuration">
                <field name="shutter_type_id"/>
                <field name="name"/>
                <field name="min_height"/>
                <field name="max_height"/>
                <field name="min_width"/>
                <field name="max_width"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_shutter_range_config_form" model="ir.ui.view">
        <field name="name">shutter.range.config.form</field>
        <field name="model">shutter.range.config</field>
        <field name="arch" type="xml">
            <form string="Shutter Range Configuration">
                <sheet>
                    <group>
                        <field name="shutter_type_id"/>
                    </group>
                    <group string="Height Range" col="2">
                        <field name="name"/>
                    </group>

                    <group string="Height Range" col="2">
                        <field name="min_height"/>
                        <field name="max_height"/>
                    </group>

                    <group string="Width Range" col="2">
                        <field name="min_width"/>
                        <field name="max_width"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_shutter_range_config" model="ir.actions.act_window">
        <field name="name">Shutter Range Config</field>
        <field name="res_model">shutter.range.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
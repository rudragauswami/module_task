<odoo>

    <!-- Tree (List) View -->
    <record id="view_shutter_component_config_tree" model="ir.ui.view">
        <field name="name">shutter.component.config.tree</field>
        <field name="model">shutter.component.config</field>
        <field name="arch" type="xml">
            <list string="Shutter Component Configuration">
                <field name="range_config_id"/>
                <field name="lock_product_id"/>
                <field name="stopper_product_id"/>
                <field name="blade_product_id"/>
                <field name="blade_qty_formula"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_shutter_component_config_form" model="ir.ui.view">
        <field name="name">shutter.component.config.form</field>
        <field name="model">shutter.component.config</field>
        <field name="arch" type="xml">
            <form string="Shutter Component Configuration">
                <sheet>

                    <group>
                        <field name="range_config_id"/>
                    </group>

                    <group string="Component Products" col="2">
                        <field name="lock_product_id"/>
                        <field name="stopper_product_id"/>
                        <field name="blade_product_id"/>
                    </group>

                    <group string="Blade Configuration">
                        <field name="blade_qty_formula"
                               placeholder="e.g. (height / 10)"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_shutter_component_config" model="ir.actions.act_window">
        <field name="name">Shutter Component Config</field>
        <field name="res_model">shutter.component.config</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>

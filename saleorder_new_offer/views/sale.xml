<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_form_dynamic_promo" model="ir.ui.view">
        <field name="name">product.template.form.dynamic.promo</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sale']" position="inside">
                <separator string="Promotion Rules" colspan="2"/>

                <group colspan="2">
                    <field name="is_promo_active" widget="boolean_toggle"/>
                    <field name="promo_threshold"/>
                    <field name="promo_reward"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_dynamic_promo" model="ir.ui.view">
        <field name="name">sale.order.form.dynamic.promo</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list//field[@name='name']" position="after">
                <field name="is_free_product" column_invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']/list" position="attributes">
                <attribute name="decoration-success">is_free_product==True</attribute>
                <attribute name="decoration-bf">is_free_product==True</attribute>
            </xpath>

        </field>
    </record>

</odoo>
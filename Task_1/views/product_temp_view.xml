<odoo>
    <record id="view_product_template_form_inherit_apron" model="ir.ui.view">
        <field name="name">product.template.form.inherit.apron</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='sales']" position="inside">
                <group>
                    <field name="is_apron_shutter"/>
                    <field name="min_height"/>
                    <field name="max_height"/>
                    <field name="min_length"/>
                    <field name="max_length"/>
                </group>

            </xpath>

        </field>
    </record>
</odoo>

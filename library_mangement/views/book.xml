<odoo>
<!--Library Management Book Form view-->
    <record id="view_lib_book_form_view" model="ir.ui.view">
        <field name="name">Library management form view</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Library Management">
                <field name="name"/>
                <field name="author_id"/>
                <field name="isbn"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="borrow_count"/>
            </form>
        </field>
    </record>
<!--    library book list view-->
    <record id="view_lib_book_list_view" model="ir.ui.view">
        <field name="name">Library management list view</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Library Management">
                <field name="name"/>
                <field name="author_id"/>
                <field name="isbn"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="borrow_count"/>
            </list>
        </field>
    </record>

    <record id="book_action" model="ir.actions.act_window">
        <field name="name">Book</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>